# ── Engram ──────────────────────────────────────────────────────────────────
# Copy to .env.local for local dev; set the same vars on your host for deploy.
#
# Most runtime behavior below is ALSO editable in the dashboard → Settings (persisted
# under ENGRAM_DATA_DIR). A saved setting OVERRIDES the matching env var and takes effect
# without a redeploy. Vars tagged "(Settings)" are optional here — set them once in the UI
# instead. The Auth block bootstraps login itself, so it must stay in env.

NEXT_PUBLIC_APP_NAME="Engram"     # (Settings) default app name; the UI value wins at runtime

# Vault = the markdown source of truth.
#   local dev (unset): ./sample-vault (bundled)
#   production: the mounted volume path
# VAULT_DIR="/data"

# ── Vault sync ── (Settings) all three are editable in the dashboard ─────────
# Vault repos are connected in the dashboard (Workspaces). Set GIT_SYNC_ENABLED=true to
# auto commit+push the active repo — or just flip it in Settings → Git sync.
GIT_SYNC_ENABLED="false"
GIT_AUTHOR_NAME="Engram"
GIT_AUTHOR_EMAIL="brain@example.com"
# ENGRAM_DATA_DIR="/data"          # app state + vault clones (on Railway: the volume)

# ── Workspaces: GitHub OAuth ── (Settings) editable in Settings → GitHub ─────
# For the "Connect GitHub" repo flow. Optional — the URL+token path needs no OAuth app.
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ── Auth ────────────────────────────────────────────────────────────────────
# Dashboard: Google sign-in restricted to an email allowlist.
# Leave AUTH_SECRET empty (or AUTH_DISABLED=true) to keep the dashboard OPEN (local dev).
ALLOWED_EMAILS=""                  # comma-separated emails allowed to sign in
AUTH_SECRET=""                     # openssl rand -base64 32, or Railway "Generate" (empty => dashboard auth off)
APP_URL="http://localhost:3000"    # public base URL (Google OAuth redirect_uri = APP_URL/api/auth/callback)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# MCP auth. Optionally set ONE shared token here, and/or create per-teammate tokens
# in the dashboard Connect page. The MCP is OPEN when no token exists (local dev).
MCP_TOKEN=""
# Where per-teammate token hashes persist (kept out of the vault git). Defaults to
# <vault>/.engram. On Railway put it on the volume, e.g. /data/.engram.
# ENGRAM_STATE_DIR="/data/.engram"

# Local/OSS single-user mode: no Google auth, MCP open. NEVER true in production.
AUTH_DISABLED="false"

# ── Harness (brain_capture) — OFF by default ── (Settings) → AI capture ──────
# Optional server-side auto-filing of rough dumps. Costs extra tokens; a coding
# agent can do the same over the plain MCP tools for free. Easiest to enable in
# the dashboard (Settings → AI capture) — toggle + paste the key there.
HARNESS_ENABLED="false"
ANTHROPIC_API_KEY=""
CAPTURE_MODEL="claude-haiku-4-5-20251001"
