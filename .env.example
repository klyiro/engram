# ── Cortex ──────────────────────────────────────────────────────────────────
# Copy to .env.local for local dev; set the same vars on your host for deploy.

NEXT_PUBLIC_APP_NAME="Cortex"

# Vault = the markdown source of truth.
#   local dev (unset): ./sample-vault (bundled)
#   production: the mounted volume path
# VAULT_DIR="/data"

# ── Vault sync ───────────────────────────────────────────────────────────────
# Vault repos are connected in the dashboard (Workspaces) via GitHub OAuth (below) —
# no GIT_REMOTE env needed. Set GIT_SYNC_ENABLED=true to auto commit+push the active repo.
GIT_SYNC_ENABLED="false"
GIT_AUTHOR_NAME="Cortex"
GIT_AUTHOR_EMAIL="brain@example.com"
# CORTEX_DATA_DIR="/data"          # app state + vault clones (on Railway: the volume)

# ── Workspaces: GitHub OAuth (connect vault repos from the dashboard) ─────────
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ── Auth ────────────────────────────────────────────────────────────────────
# Dashboard: Google sign-in restricted to an email allowlist.
# Leave AUTH_SECRET empty (or AUTH_DISABLED=true) to keep the dashboard OPEN (local dev).
ALLOWED_EMAILS=""                  # comma-separated emails allowed to sign in
AUTH_SECRET=""                     # openssl rand -base64 32, or Railway "Generate" (empty => dashboard auth off)
APP_URL="http://localhost:3000"    # public base URL (Google OAuth redirect_uri = APP_URL/api/auth/callback)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# MCP auth. Optionally set ONE shared token here, and/or create per-teammate tokens
# in the dashboard Connect page. The MCP is OPEN when no token exists (local dev).
MCP_TOKEN=""
# Where per-teammate token hashes persist (kept out of the vault git). Defaults to
# <vault>/.cortex. On Railway put it on the volume, e.g. /data/.cortex.
# CORTEX_STATE_DIR="/data/.cortex"

# Local/OSS single-user mode: no Google auth, MCP open. NEVER true in production.
AUTH_DISABLED="false"

# ── Harness (brain_capture) — OFF by default ─────────────────────────────────
# Optional server-side auto-filing of rough dumps. Costs extra tokens; a coding
# agent can do the same over the plain MCP tools for free. Enable both to turn on.
HARNESS_ENABLED="false"
ANTHROPIC_API_KEY=""
CAPTURE_MODEL="claude-haiku-4-5-20251001"
